# Firebase Realtime Database 설정
# 1. https://console.firebase.google.com → 새 프로젝트 생성
# 2. 빌드 > Realtime Database → 데이터베이스 만들기 (테스트 모드)
# 3. 프로젝트 설정 → 내 앱 → 웹앱 등록 → 아래 값 복사

VITE_FB_API_KEY=AIzaSy...
VITE_FB_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FB_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FB_PROJECT_ID=your-project
VITE_FB_STORAGE_BUCKET=your-project.appspot.com
VITE_FB_MESSAGING_SENDER_ID=123456789
VITE_FB_APP_ID=1:123456789:web:abc123

# 이 파일을 .env.local 로 복사하고 값을 채워넣은 후 npm run dev 또는 npm run build
